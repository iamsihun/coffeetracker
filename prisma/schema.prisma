generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bean {
  id        String    @id @default(cuid())
  name      String
  roaster   String?
  origin    String?
  notes     String?
  roastDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  brews     Brew[]
}

model Brew {
  id         String   @id @default(cuid())
  beanId     String
  bean       Bean     @relation(fields: [beanId], references: [id], onDelete: Cascade)
  grindSize  String
  gramsIn    Float
  gramsOut   Float
  brewTime   String
  brewMethod String
  notes      String?
  grinder    String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
}
